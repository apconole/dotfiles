#  COLOR CONSTANTS
#  Bunch-o-predefined colors.  Makes reading code easier than escape sequences.
#  I don't remember where I found this, but sourcing it is useful.  o_O

# Reset
Color_Off_="\033[0m"          # Text Reset
Color_Off="\[$Color_Off_\]"   # Text Reset

# Regular Colors
Black_="\033[0;30m"           # Black
Black="\[$Black\]"            # Black
Red_="\033[0;31m"             # Red
Red="\[$Red_\]"               # Red
Green_="\033[0;32m"           # Green
Green="\[$Green_\]"           # Green
Yellow_="\033[0;33m"          # Yellow
Yellow="\[$Yellow_\]"         # Yellow
Blue_="\033[0;34m"            # Blue
Blue="\[$Blue_\]"             # Blue
Purple_="\033[0;35m"          # Purple
Purple="\[$Purple_\]"         # Purple
Cyan_="\033[0;36m"            # Cyan
Cyan="\[$Cyan_\]"             # Cyan
White_="\033[0;37m"           # White
White="\[$White\]"            # White

# Bold
BBlack_="\033[1;30m"          # Black
BBlack="\[$BBlack_\]"         # Black
BRed_="\033[1;31m"            # Red
BRed="\[$BRed_\]"             # Red
BGreen_="\033[1;32m"          # Green
BGreen="\[$BGreen_\]"         # Green
BYellow_="\033[1;33m"         # Yellow
BYellow="\[$BYellow_\]"       # Yellow
BBlue_="\033[1;34m"           # Blue
BBlue="\[$BBlue_\]"           # Blue
BPurple_="\033[1;35m"         # Purple
BPurple="\[$BPurple_\]"       # Purple
BCyan_="\033[1;36m"           # Cyan
BCyan="\[$BCyan_\]"           # Cyan
BWhite_="\033[1;37m"          # White
BWhite="\[$BWhite_\]"         # White

# Underline
UBlack_="\033[4;30m"          # Black
UBlack="\[$UBlack_\]"         # Black
URed_="\033[4;31m"            # Red
URed="\[$URed_\]"             # Red
UGreen_="\033[4;32m"          # Green
UGreen="\[$UGreen_\]"         # Green
UYellow_="\033[4;33m"         # Yellow
UYellow="\[$UYellow_\]"       # Yellow
UBlue_="\033[4;34m"           # Blue
UBlue="\[$UBlue_\]"           # Blue
UPurple_="\033[4;35m"         # Purple
UPurple="\[$UPurple_\]"       # Purple
UCyan_="\033[4;36m"           # Cyan
UCyan="\[$UCyan_\]"           # Cyan
UWhite_="\033[4;37m"          # White
UWhite="\[$UWhite_\]"         # White

# Background
On_Black="\[\033[40m\]"       # Black
On_Black="\[\033[40m\]"       # Black
On_Red="\[\033[41m\]"         # Red
On_Green="\[\033[42m\]"       # Green
On_Yellow="\[\033[43m\]"      # Yellow
On_Blue="\[\033[44m\]"        # Blue
On_Purple="\[\033[45m\]"      # Purple
On_Cyan="\[\033[46m\]"        # Cyan
On_White="\[\033[47m\]"       # White

# High Intensty
IBlack_="\033[0;90m"          # Black
IBlack="\[$IBlack_\]"         # Black
IRed_="\033[0;91m"            # Red
IRed="\[$IRed_\]"             # Red
IGreen_="\033[0;92m"          # Green
IGreen="\[$IGreen_\]"         # Green
IYellow_="\033[0;93m"         # Yellow
IYellow="\[$IYellow_\]"       # Yellow
IBlue_="\033[0;94m"           # Blue
IBlue="\[$IBlue_\]"           # Blue
IPurple_="\033[0;95m"         # Purple
IPurple="\[$IPurple_\]"       # Purple
ICyan_="\033[0;96m"           # Cyan
ICyan="\[$ICyan_\]"           # Cyan
IWhite_="\033[0;97m"          # White
IWhite="\[$IWhite_\]"         # White

# Bold High Intensty
BIBlack_="\033[1;90m"         # Black
BIBlack="\[$BIBlack_\]"       # Black
BIRed_="\033[1;91m"           # Red
BIRed="\[$BIRed_\]"           # Red
BIGreen_="\033[1;92m"         # Green
BIGreen="\[$BIGreen_\]"       # Green
BIYellow_="\033[1;93m"        # Yellow
BIYellow="\[$BIYellow_\]"     # Yellow
BIBlue_="\033[1;94m"          # Blue
BIBlue="\[$BIBlue_\]"         # Blue
BIPurple_="\033[1;95m"        # Purple
BIPurple="\[$BIPurple_\]"     # Purple
BICyan_="\033[1;96m"          # Cyan
BICyan="\[$BICyan_\]"         # Cyan
BIWhite_="\033[1;97m"         # White
BIWhite="\[$BIWhite_\]"       # White

# High Intensty backgrounds
On_IBlack="\[\033[0;100m\]"   # Black
On_IRed="\[\033[0;101m\]"     # Red
On_IGreen="\[\033[0;102m\]"   # Green
On_IYellow="\[\033[0;103m\]"  # Yellow
On_IBlue="\[\033[0;104m\]"    # Blue
On_IPurple="\[\033[10;95m\]"  # Purple
On_ICyan="\[\033[0;106m\]"    # Cyan
On_IWhite="\[\033[0;107m\]"   # White
